<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/purple_light">

    <!-- Purple Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple_primary"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QuickAid"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Request Resources"
            android:textColor="#d4c8f0"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Form Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="📦"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@drawable/circle_purple_light"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Resource Request Form"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#2d1b69"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fill out all required fields"
                                android:textSize="12sp"
                                android:textColor="@color/gray_text"/>

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Resource Type -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resource Type *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2d1b69"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerResourceType"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Quantity -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quantity *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2d1b69"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/input_bg"
                        android:layout_marginBottom="16dp">

                        <Button
                            android:id="@+id/btnDecrease"
                            android:layout_width="48dp"
                            android:layout_height="match_parent"
                            android:text="-"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/purple_primary"
                            android:background="@android:color/transparent"/>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/card_border"/>

                        <TextView
                            android:id="@+id/tvQuantity"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="1"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2d1b69"
                            android:gravity="center"/>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/card_border"/>

                        <Button
                            android:id="@+id/btnIncrease"
                            android:layout_width="48dp"
                            android:layout_height="match_parent"
                            android:text="+"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/purple_primary"
                            android:background="@android:color/transparent"/>

                    </LinearLayout>

                    <!-- Urgency Level -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Urgency Level *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2d1b69"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerUrgency"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Delivery Location -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Location *"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2d1b69"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etLocation"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Enter delivery address"
                        android:textSize="13sp"
                        android:textColorHint="@color/gray_text"
                        android:background="@drawable/input_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="text"
                        android:layout_marginBottom="16dp"/>

                    <!-- Additional Details -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Additional Details"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2d1b69"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etDetails"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:hint="Provide any additional information about your request..."
                        android:textSize="13sp"
                        android:textColorHint="@color/gray_text"
                        android:background="@drawable/input_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="10dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recent Requests -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Requests"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2d1b69"
                android:layout_marginBottom="10dp"/>

            <!-- Request 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medical Supplies"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2d1b69"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Qty: 50 units • 123 Oak Street"
                            android:textSize="11sp"
                            android:textColor="@color/gray_text"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Approved"
                        android:textSize="11sp"
                        android:textColor="#1D9E75"
                        android:background="@drawable/badge_green"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Request 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Food &amp; Water"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2d1b69"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Qty: 100 units • 456 Pine Avenue"
                            android:textSize="11sp"
                            android:textColor="@color/gray_text"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textSize="11sp"
                        android:textColor="#854f0b"
                        android:background="@drawable/badge_pending"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Submit Button -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/purple_primary">

                <LinearLayout
                    android:id="@+id/btnSubmitRequest"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➤  Submit Request"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>