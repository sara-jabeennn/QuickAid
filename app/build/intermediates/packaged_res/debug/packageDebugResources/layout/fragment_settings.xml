<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/purple_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/purple_primary"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:background="@android:color/transparent"
                android:tint="@color/white"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage your preferences"
                    android:textColor="#d4c8f0"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Preferences Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preferences"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/gray_text"
                android:layout_marginBottom="8dp"
                android:paddingStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Push Notifications -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_bell" app:tint="@color/purple_primary" android:layout_marginEnd="14dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Push Notifications" android:textSize="14sp" android:textColor="#2d1b69"/>
                        <Switch
                            android:id="@+id/switchNotifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="@color/purple_primary"
                            android:trackTint="#d4c8f0"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/card_border" android:layout_marginStart="48dp"/>

                    <!-- Location -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_location" app:tint="@color/purple_primary" android:layout_marginEnd="14dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Location Access" android:textSize="14sp" android:textColor="#2d1b69"/>
                        <Switch
                            android:id="@+id/switchLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="@color/purple_primary"
                            android:trackTint="#d4c8f0"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/card_border" android:layout_marginStart="48dp"/>

                    <!-- Dark Mode -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_settings" app:tint="@color/purple_primary" android:layout_marginEnd="14dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dark Mode" android:textSize="14sp" android:textColor="#2d1b69"/>
                        <Switch
                            android:id="@+id/switchDarkMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:thumbTint="@color/purple_primary"
                            android:trackTint="#d4c8f0"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/card_border" android:layout_marginStart="48dp"/>

                    <!-- Language -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_web" app:tint="@color/purple_primary" android:layout_marginEnd="14dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Language" android:textSize="14sp" android:textColor="#2d1b69"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="English" android:textSize="13sp" android:textColor="@color/gray_text"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- App Info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App Info"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/gray_text"
                android:layout_marginBottom="8dp"
                android:paddingStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Version -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_info" app:tint="@color/purple_primary" android:layout_marginEnd="14dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="App Version" android:textSize="14sp" android:textColor="#2d1b69"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="v1.0.0" android:textSize="13sp" android:textColor="@color/gray_text"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>