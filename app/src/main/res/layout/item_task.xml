<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/priorityDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/circle_amber"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTaskType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task Type"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2d1b69"/>

            <TextView
                android:id="@+id/tvVictimName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Victim Name"
                android:textSize="11sp"
                android:textColor="@color/gray_text"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="11sp"
                android:textColor="@color/gray_text"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assigned"
            android:textSize="11sp"
            android:textColor="@color/purple_primary"
            android:background="@drawable/badge_assigned"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>