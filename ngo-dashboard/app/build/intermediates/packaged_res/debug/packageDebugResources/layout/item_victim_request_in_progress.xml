<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/requestCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="2dp"
    app:strokeColor="#42A5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Name and Status Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/victimName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Robert Lee"
                    android:textSize="18sp"
                    android:textColor="@android:color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/categoryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rescue"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En Route"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:background="@drawable/badge_in_progress"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Location" />

            <TextView
                android:id="@+id/locationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Downtown Area, 555 Center St"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Assigned Team -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_team"
                android:contentDescription="Team" />

            <TextView
                android:id="@+id/assignedTeamText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assigned to: Team Alpha-3"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- ETA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_time"
                android:contentDescription="ETA" />

            <TextView
                android:id="@+id/etaText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ETA: 10 min"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Started Time -->
        <TextView
            android:id="@+id/startedTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Started 20 min ago"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginTop="12dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/contactTeamBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Contact Team"
                android:textSize="13sp"
                android:textColor="#666666"
                android:textAllCaps="false"
                android:background="@drawable/button_victim_request_outline"
                android:paddingHorizontal="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginEnd="8dp"
                style="?attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/trackBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Track"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:background="@drawable/button_track"
                android:paddingHorizontal="20dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>