<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:id="@+id/nav_graph"
app:startDestination="@id/homeFragment" >
<fragment
    android:id="@+id/homeFragment"
    android:name="com.fyp.quickaid.volunteer.HomeFragment"
    android:label="Home" />
<fragment
    android:id="@+id/tasksFragment"
    android:name="com.fyp.quickaid.volunteer.TasksFragment"
    android:label="Tasks" />
<fragment
    android:id="@+id/chatFragment"
    android:name="com.fyp.quickaid.volunteer.ChatFragment"
    android:label="Chat" />
<fragment
    android:id="@+id/resourcesFragment"
    android:name="com.fyp.quickaid.volunteer.ResourcesFragment"
    android:label="Resources" />
<fragment
    android:id="@+id/profileFragment"
    android:name="com.fyp.quickaid.volunteer.ProfileFragment"
    android:label="Profile" />
<fragment
    android:id="@+id/locateVictimsFragment"
    android:name="com.fyp.quickaid.volunteer.LocateVictimsFragment"
    android:label="Locate Victims" >

    <action
        android:id="@+id/action_locateVictimsFragment_to_victimDetailsFragment"
        app:destination="@id/victimDetailsFragment" />

</fragment>
<fragment
    android:id="@+id/victimDetailsFragment"
    android:name="com.fyp.quickaid.volunteer.VictimDetailsFragment"
    android:label="Victim Details" >

    <argument
        android:name="name"
        app:argType="string" />
    <argument
        android:name="type"
        app:argType="string" />
    <argument
        android:name="priority"
        app:argType="string" />
    <argument
        android:name="location"
        app:argType="string" />

</fragment>
<fragment
    android:id="@+id/notificationsFragment"
    android:name="com.fyp.quickaid.volunteer.NotificationsFragment"
    android:label="Notifications" />
<fragment
    android:id="@+id/settingsFragment"
    android:name="com.fyp.quickaid.volunteer.SettingsFragment"
    android:label="Settings" />
<fragment
    android:id="@+id/privacyFragment"
    android:name="com.fyp.quickaid.volunteer.PrivacyFragment"
    android:label="Privacy" />
<fragment
    android:id="@+id/helpFragment"
    android:name="com.fyp.quickaid.volunteer.HelpFragment"
    android:label="Help" />
</navigation>