<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/requestCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="2dp"
    app:strokeColor="#EF5350">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Name, Badge, Team Count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/victimName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="John Doe"
                android:textSize="18sp"
                android:textColor="@android:color/black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/priorityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="critical"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:background="@drawable/badge_critical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_team"
                    android:contentDescription="Team" />

                <TextView
                    android:id="@+id/teamCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Category -->
        <TextView
            android:id="@+id/categoryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rescue"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginTop="8dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/descriptionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trapped in flooded building, water level rising"
            android:textSize="14sp"
            android:textColor="#333333"
            android:layout_marginTop="8dp" />

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Location" />

            <TextView
                android:id="@+id/locationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Downtown Area, 123 Main St"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_time"
                android:contentDescription="Time" />

            <TextView
                android:id="@+id/timeAgoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requested 5 min ago"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Phone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_phone"
                android:contentDescription="Phone" />

            <TextView
                android:id="@+id/phoneNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+1 (555) 0123"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/assignTeamBtn"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Assign Team"
                android:textSize="13sp"
                android:textColor="#666666"
                android:textAllCaps="false"
                android:background="@drawable/button_victim_request_outline"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginEnd="8dp"
                style="?attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/viewDetailsBtn"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="View Details"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:background="@drawable/button_victim_request_filled"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>