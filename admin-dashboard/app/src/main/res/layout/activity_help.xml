<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="44dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView android:id="@+id/ivBack"
                android:layout_width="36dp" android:layout_height="36dp"
                android:padding="4dp" android:src="@drawable/ic_arrow_back"
                android:tint="@android:color/white" />
            <LinearLayout android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Help &amp; Documentation"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get support and answers"
                    android:textColor="#CCffffff" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- FAQ Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Frequently Asked Questions"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" android:textStyle="bold" />

                    <LinearLayout android:id="@+id/layoutFaq1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="How do I approve a user?"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvFaq1Answer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Go to User Management → find the user → tap Approve button."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout android:id="@+id/layoutFaq2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="How to send a broadcast alert?"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvFaq2Answer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Go to Dashboard → Quick Actions → Send Alerts → compose and send."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout android:id="@+id/layoutFaq3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="How to verify a report?"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvFaq3Answer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Go to Dashboard → Quick Actions → Verify Reports → review and approve/reject."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Contact Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Contact Support"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" android:textStyle="bold" />

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        <ImageView android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_email"
                            android:tint="@color/purple_primary" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="support@quickaid.org"
                            android:textColor="@color/purple_primary"
                            android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>

                    <Button android:id="@+id/btnContactSupport"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button_gradient"
                        android:text="Send Email to Support"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- App Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical" android:padding="20dp">

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QuickAid"
                        android:textColor="@color/purple_primary"
                        android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disaster Management System"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Version v1.0.0"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>