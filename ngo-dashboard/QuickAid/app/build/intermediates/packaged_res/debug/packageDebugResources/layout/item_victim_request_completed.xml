<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/requestCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#E8F5E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Checkmark Icon -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check_circle"
            android:contentDescription="Completed"
            android:layout_marginEnd="12dp" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/victimName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tom Brown"
                android:textSize="18sp"
                android:textColor="@android:color/black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/categoryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Evacuation"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp" />

            <!-- Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location"
                    android:contentDescription="Location" />

                <TextView
                    android:id="@+id/locationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="North Zone, 111 Hill Rd"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Completed By Team -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_team"
                    android:contentDescription="Team" />

                <TextView
                    android:id="@+id/completedByText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed by: Team Beta-1"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- People Helped -->
            <TextView
                android:id="@+id/peopleHelpedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6 people helped"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp" />

            <!-- Completed Time -->
            <TextView
                android:id="@+id/completedTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completed 2 hours ago"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginTop="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>